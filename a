    properties: ['openDirectory']
  });
  return result.filePaths[0];
});

// ── Scan Paths (Recursion) ──
ipcMain.handle('scan-paths', async (event, { paths, options }) => {
  const processedFiles = [];
  const { mode, includeSubfolders, fileMask, regexMatch, addSubfolders, addRoot } = options;

  let maskRegex = null;
  if (fileMask) {
    const escaped = fileMask.replace(/[.+^${}()|[\]\\]/g, '\\$&').replace(/\*/g, '.*').replace(/\?/g, '.');
    maskRegex = new RegExp('^' + escaped + '$', 'i');
  }

  let customRegex = null;
  if (regexMatch) {
    try { customRegex = new RegExp(regexMatch); } catch (e) { }
  }

  function matches(name) {
    if (maskRegex && !maskRegex.test(name)) return false;
    if (customRegex && !customRegex.test(name)) return false;
    return true;
  }

  function traverse(currentPath, depth) {
    let stat;
    try { stat = fs.statSync(currentPath); } catch (e) { return; }

    const isFile = stat.isFile();
    const isDir = stat.isDirectory();
    const name = path.basename(currentPath);

    if (isFile) {
      if (mode === 'files') {
        if (matches(name)) {
          processedFiles.push({ name, path: currentPath, size: stat.size, isFile: true });
        }
      }
    } else if (isDir) {
      if (depth === 0 && mode === 'folders' && addRoot) {
        processedFiles.push({ name, path: currentPath, size: 0, isFile: false });
      }

      const shouldRecurse = depth === 0 || (mode === 'files' && includeSubfolders) || (mode === 'folders' && addSubfolders);

      if (shouldRecurse) {
        let items = [];
        try { items = fs.readdirSync(currentPath); } catch (e) { }
        for (const item of items) {
          const itemPath = path.join(currentPath, item);
          let itemStat;
          try { itemStat = fs.statSync(itemPath); } catch(e) { continue; }

          if (itemStat.isDirectory()) {
            if (mode === 'folders' && addSubfolders) {
              processedFiles.push({ name: item, path: itemPath, size: 0, isFile: false });
            }
            traverse(itemPath, depth + 1);
          } else if (itemStat.isFile()) {
            traverse(itemPath, depth + 1);
          }
        }
      }
    }
  }

  for (const p of paths) {
    traverse(p, 0);
  }

  // Deduplicate in case overlapping folders are dropped
  const uniqueFiles = [];
  const handled = new Set();
  for (const f of processedFiles) {
    if (!handled.has(f.path)) {
      handled.add(f.path);
      uniqueFiles.push(f);
    }
  }
  return uniqueFiles;
});

// ── Rename Files ──
ipcMain.handle('rename-files', async (event, { folder, files, actionType = 'rename', targetFolder = null }) => {
  const results = { success: 0, errors: 0 };
  const successfulRenames = [];

  for (const file of files) {
    const oldPath = file.path;
    const baseFolder = (actionType === 'move' || actionType === 'copy') && targetFolder ? targetFolder : path.dirname(oldPath);
    const newPath = path.join(baseFolder, file.newName);

    if (oldPath === newPath || (actionType === 'copy' && oldPath.toLowerCase() === newPath.toLowerCase())) {
      results.success++;
      continue;
    }

    try {
      if (actionType === 'copy') {
        await fs.promises.cp(oldPath, newPath, { recursive: true });
      } else {
        // 'rename' or 'move'
        try {
          await fs.promises.rename(oldPath, newPath);
        } catch (renameErr) {
          if (renameErr.code === 'EXDEV') {
            await fs.promises.cp(oldPath, newPath, { recursive: true });
            await fs.promises.rm(oldPath, { recursive: true, force: true });
          } else {
            throw renameErr;
          }
        }
      }
      results.success++;
      successfulRenames.push({ oldPath, newPath, oldName: file.oldName, newName: file.newName, action: actionType });
    } catch (err) {
      console.error(`${actionType} error: ${file.oldName} → ${file.newName}`, err.message);
      results.errors++;
    }
  }

  // Save to history if any files were renamed
  if (successfulRenames.length > 0) {
    const history = loadHistory();
    history.unshift({
      id: Date.now().toString(),
      timestamp: Date.now(),
      folder: folder,
      count: successfulRenames.length,
      operations: successfulRenames
    });
    saveHistory(history);
  }

  return results;
});

// ── Get History ──
ipcMain.handle('get-history', async () => {
  return loadHistory();
});

// ── Undo Batch ──
ipcMain.handle('undo-batch', async (event, batchId) => {
  const history = loadHistory();
  const batchIndex = history.findIndex(b => b.id === batchId);
  if (batchIndex === -1) return { success: false, error: 'Kayıt bulunamadı.' };

  const batch = history[batchIndex];
  let successCount = 0;
  let errorCount = 0;

  // Undo in reverse order
  const ops = [...batch.operations].reverse();
  for (const op of ops) {
    try {
      // In undo, we move from newPath back to oldPath
      if (fs.existsSync(op.newPath)) {
        if (op.action === 'copy') {
          await fs.promises.rm(op.newPath, { recursive: true, force: true });
        } else {
          try {
            await fs.promises.rename(op.newPath, op.oldPath);
          } catch (renameErr) {
            if (renameErr.code === 'EXDEV') {
              await fs.promises.cp(op.newPath, op.oldPath, { recursive: true });
              await fs.promises.rm(op.newPath, { recursive: true, force: true });
            } else {
              throw renameErr;
            }
          }
        }
        successCount++;
      } else {
        errorCount++;
      }
    } catch (e) {
      errorCount++;
    }
  }

  // Remove this batch from history
  history.splice(batchIndex, 1);
  saveHistory(history);

  return { success: true, undone: successCount, errors: errorCount };
});

