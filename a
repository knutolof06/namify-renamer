  --accent-hover: #f97316;
  --accent-glow: rgba(251, 146, 60, 0.25);
  --purple: #f43f5e;
}

body.theme-cyberpunk {
  --bg: #0d021c;
  --bg-subtle: #14042b;
  --surface: #1e073d;
  --surface-hover: #290a54;
  --surface-active: #320c66;
  --accent: #d946ef;
  --accent-hover: #c026d3;
  --accent-glow: rgba(217, 70, 239, 0.25);
  --purple: #f43f5e;
  --green: #22d3ee;
}

body.theme-light {
  --bg: #f8fafc;
  --bg-subtle: #f1f5f9;
  --surface: #ffffff;
  --surface-hover: #e2e8f0;
  --surface-active: #cbd5e1;
  --border: rgba(0, 0, 0, 0.08);
  --border-hover: rgba(0, 0, 0, 0.15);
  --text: #0f172a;
  --text-secondary: #334155;
  --text-muted: #64748b;
  --accent: #4f46e5;
  --accent-hover: #4338ca;
  --accent-glow: rgba(79, 70, 229, 0.25);
}

* { margin: 0; padding: 0; box-sizing: border-box; }

body {
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
  background: var(--bg);
  color: var(--text);
  overflow: hidden;
  height: 100vh;
  -webkit-font-smoothing: antialiased;
}

/* ── Title Bar ── */
#titlebar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 38px;
  background: rgba(10, 10, 15, 0.95);
  border-bottom: 1px solid var(--border);
  -webkit-app-region: drag;
  padding: 0 8px 0 14px;
  position: relative;
  z-index: 100;
}

.titlebar-drag {
  display: flex;
  align-items: center;
  gap: 8px;
}

.titlebar-title {
  font-size: 12px;
  font-weight: 600;
  color: var(--text-secondary);
  letter-spacing: 0.5px;
}

.titlebar-controls {
  display: flex;
  -webkit-app-region: no-drag;
}

.tb-btn {
  width: 40px;
  height: 32px;
  border: none;
  background: transparent;
  color: var(--text-secondary);
  font-size: 11px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: var(--transition);
  border-radius: 4px;
}
.tb-btn:hover { background: rgba(255,255,255,0.06); color: var(--text); }
.tb-close:hover { background: #e81123; color: white; }

/* ── App Layout ── */
#app {
  display: flex;
  height: calc(100vh - 38px);
  position: relative;
}

/* ── Ambient Background ── */
.ambient-bg {
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 0;
  overflow: hidden;
}

.orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(120px);
  opacity: 0.3;
}
.orb-1 {
  width: 500px; height: 500px;
  background: radial-gradient(circle, #6366f130, transparent 70%);
  top: -10%; left: -5%;
  animation: float1 20s ease-in-out infinite;
}
.orb-2 {
  width: 400px; height: 400px;
  background: radial-gradient(circle, #a78bfa20, transparent 70%);
  bottom: -10%; right: -5%;
  animation: float2 25s ease-in-out infinite;
}
.orb-3 {
  width: 300px; height: 300px;
  background: radial-gradient(circle, #818cf815, transparent 70%);
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  animation: float3 15s ease-in-out infinite;
}

@keyframes float1 { 0%,100%{transform:translate(0,0)} 50%{transform:translate(40px,30px)} }
@keyframes float2 { 0%,100%{transform:translate(0,0)} 50%{transform:translate(-30px,-40px)} }
@keyframes float3 { 0%,100%{transform:translate(-50%,-50%) scale(1)} 50%{transform:translate(-50%,-50%) scale(1.2)} }

/* ── Sidebar ── */
#sidebar {
  width: 240px;
  min-width: 240px;
  background: var(--bg-subtle);
  border-right: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 24px 16px 20px;
  position: relative;
  z-index: 1;
}

.logo-section {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 32px;
}

.logo-mark {
  width: 40px;
  height: 40px;
  background: linear-gradient(135deg, #6366f1, #a78bfa);
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 20px rgba(99, 102, 241, 0.3);
}

.logo-text {
  font-size: 20px;
  font-weight: 800;
  letter-spacing: -0.5px;
  background: linear-gradient(135deg, #818cf8, #c084fc);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
}

.logo-sub {
  font-size: 11px;
  color: var(--text-muted);
  margin-top: 1px;
}

.sidebar-nav {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.nav-item {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 12px;
  border: none;
  border-radius: var(--radius);
  background: transparent;
  color: var(--text-secondary);
  font-size: 13.5px;
  font-weight: 500;
  cursor: pointer;
  transition: var(--transition);
  font-family: inherit;
}
.nav-item:hover { background: var(--surface); color: var(--text); }
.nav-item.active {
  background: linear-gradient(135deg, rgba(99,102,241,0.12), rgba(139,92,246,0.08));
  color: var(--accent);
  box-shadow: inset 0 0 0 1px rgba(99,102,241,0.15);
}

.sidebar-stats {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
}

.stat-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 14px 12px;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.stat-num {
  font-size: 22px;
  font-weight: 700;
  background: linear-gradient(135deg, #818cf8, #c084fc);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
}

.stat-label {
  font-size: 10.5px;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.5px;
  font-weight: 600;
}

/* ── Main Content ── */
#main-content {
  flex: 1;
  padding: 24px 28px;
  overflow-y: auto;
  position: relative;
  z-index: 1;
}

/* ── Drop Zone ── */
.drop-zone {
  border: 2px dashed var(--border);
  border-radius: var(--radius-xl);
  background: linear-gradient(135deg, rgba(99,102,241,0.02), rgba(139,92,246,0.02));
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: calc(100vh - 38px - 48px);
  cursor: pointer;
  transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

.drop-zone::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(600px circle at var(--mouse-x, 50%) var(--mouse-y, 50%), rgba(99,102,241,0.06), transparent 60%);
  transition: opacity 0.3s;
  opacity: 0;
}

.drop-zone:hover::before { opacity: 1; }

.drop-zone.drag-over {
  border-color: var(--accent);
  background: linear-gradient(135deg, rgba(99,102,241,0.06), rgba(139,92,246,0.04));
  transform: scale(0.995);
  box-shadow: 0 0 60px -10px var(--accent-glow);
}

.drop-zone.drag-over .drop-icon-ring { animation-play-state: running; }

.drop-inner {
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16px;
}

.drop-icon-wrapper {
  position: relative;
  width: 80px;
  height: 80px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.drop-icon {
  color: var(--accent);
  position: relative;
  z-index: 2;
  filter: drop-shadow(0 0 8px var(--accent-glow));
}

.drop-icon-ring {
  position: absolute;
  width: 80px;
  height: 80px;
  border: 2px solid rgba(129, 140, 248, 0.15);
  border-radius: 50%;
  animation: ring-pulse 3s ease-in-out infinite;
  animation-play-state: paused;
}

.ring-2 {
  width: 100px;
  height: 100px;
  animation-delay: 0.5s;
  border-color: rgba(129, 140, 248, 0.08);
}

@keyframes ring-pulse {
  0%,100% { transform: scale(0.9); opacity: 0.5; }
  50% { transform: scale(1.15); opacity: 1; }
}

.drop-title {
  font-size: 22px;
  font-weight: 700;
  letter-spacing: -0.3px;
}

.drop-subtitle {
  color: var(--text-muted);
  font-size: 14px;
}

.drop-badge {
  display: flex;
  align-items: center;
  gap: 6px;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 100px;
  padding: 6px 14px;
  font-size: 12px;
  color: var(--text-secondary);
  margin-top: 8px;
}

.badge-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--green);
  box-shadow: 0 0 6px var(--green);
}

/* ── Modal ── */
.modal-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.6);
  backdrop-filter: blur(8px);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 50;
  animation: fadeIn 0.2s ease;
}

.modal {
  background: var(--surface);
  border: 1px solid var(--border-hover);
  border-radius: var(--radius-xl);
  width: 560px;
  max-width: 95vw;
  box-shadow: 0 25px 60px -15px rgba(0,0,0,0.6), 0 0 40px -10px var(--accent-glow);
  animation: modalIn 0.35s cubic-bezier(0.16, 1, 0.3, 1);
}

@keyframes fadeIn { from{opacity:0} to{opacity:1} }
@keyframes modalIn { from{opacity:0;transform:scale(0.95) translateY(10px)} to{opacity:1;transform:scale(1) translateY(0)} }

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20px 24px;
  border-bottom: 1px solid var(--border);
}

.modal-header h3 {
  font-size: 16px;
  font-weight: 700;
}

.modal-close-btn {
  width: 32px;
  height: 32px;
  border: none;
  background: transparent;
  color: var(--text-muted);
  cursor: pointer;
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: var(--transition);
}
.modal-close-btn:hover { background: var(--surface-hover); color: var(--text); }

.modal-body { padding: 20px 24px; display: flex; flex-direction: column; gap: 12px; }
.modal-footer { padding: 16px 24px; border-top: 1px solid var(--border); display: flex; justify-content: flex-end; gap: 10px; }

/* ── Option Blocks ── */
.option-block {
  display: flex;
  cursor: pointer;
  position: relative;
}

.option-block > input[type="radio"] { display: none; }

.option-content {
  width: 100%;
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 16px 18px;
  background: var(--bg-subtle);
  transition: var(--transition);
}

.option-block > input:checked + .option-content {
  border-color: var(--accent);
  background: linear-gradient(135deg, rgba(99,102,241,0.06), rgba(139,92,246,0.03));
  box-shadow: 0 0 20px -8px var(--accent-glow);
}

.option-header {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 4px;
}

.option-icon {
  width: 38px;
  height: 38px;
  border-radius: var(--radius);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.files-icon { background: rgba(99,102,241,0.12); color: var(--accent); }
.folders-icon { background: rgba(251,146,60,0.12); color: var(--orange); }

.option-label {
  display: block;
  font-weight: 600;
  font-size: 14px;
}

.option-desc {
  display: block;
  font-size: 12px;
  color: var(--text-muted);
  margin-top: 2px;
}

.option-details {
  margin-top: 14px;
  padding-top: 14px;
  border-top: 1px solid var(--border);
  display: none; /* Hidden by default */
  flex-direction: column;
  gap: 12px;
}

input[type="radio"]:checked + .option-content .option-details {
  display: flex;
}

/* ── Toggle Switch ── */
.toggle-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 13px;
  color: var(--text-secondary);
  cursor: pointer;
}

.toggle-switch { position: relative; width: 40px; height: 22px; }
.toggle-switch input { display: none; }

.toggle-slider {
  position: absolute;
  inset: 0;
  background: var(--surface-hover);
  border-radius: 100px;
  transition: var(--transition);
  border: 1px solid var(--border);
}

.toggle-slider::after {
  content: '';
  position: absolute;
  width: 16px;
  height: 16px;
  border-radius: 50%;
  background: var(--text-secondary);
  top: 2px;
  left: 3px;
  transition: var(--transition);
}

.toggle-switch input:checked + .toggle-slider {
  background: var(--accent);
  border-color: var(--accent);
}

.toggle-switch input:checked + .toggle-slider::after {
  transform: translateX(17px);
  background: white;
}

/* ── Field Inputs ── */
.field-group { display: flex; flex-direction: column; gap: 5px; }

.field-label {
  font-size: 12px;
  color: var(--text-muted);
  font-weight: 500;
}

.field-input {
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 9px 12px;
  color: var(--text);
  font-size: 13px;
  font-family: 'Inter', sans-serif;
  outline: none;
  transition: var(--transition);
}

.field-input:focus {
  border-color: var(--accent);
  box-shadow: 0 0 0 3px var(--accent-glow);
}

.field-input::placeholder { color: var(--text-muted); }

/* ── Buttons ── */
.btn {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  border: none;
  border-radius: var(--radius);
  font-family: 'Inter', sans-serif;
  font-weight: 600;
  cursor: pointer;
  transition: var(--transition);
  font-size: 13px;
  padding: 9px 18px;
}

.btn-primary {
  background: linear-gradient(135deg, #6366f1, #7c3aed);
  color: white;
  box-shadow: 0 4px 15px -3px rgba(99,102,241,0.4);
}
.btn-primary:hover {
  box-shadow: 0 6px 20px -3px rgba(99,102,241,0.5);
  transform: translateY(-1px);
}

.btn-ghost {
  background: transparent;
  color: var(--text-secondary);
}
.btn-ghost:hover { color: var(--text); background: var(--surface-hover); }

.btn-ghost-danger {
  background: transparent;
  color: var(--text-muted);
}
.btn-ghost-danger:hover { color: var(--red); background: var(--red-bg); }

.btn-outline {
  background: transparent;
  border: 1px solid var(--border);
  color: var(--text-secondary);
}
.btn-outline:hover { border-color: var(--accent); color: var(--accent); }

.btn-sm { padding: 6px 12px; font-size: 12px; border-radius: var(--radius-sm); }
.btn-lg { padding: 12px 28px; font-size: 14px; border-radius: var(--radius-lg); }

/* ── List Panel ── */
.list-panel {
  display: flex;
  flex-direction: column;
  height: calc(100vh - 38px - 48px);
  animation: fadeIn 0.3s ease;
}

.list-toolbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16px;
  flex-wrap: wrap;
  gap: 10px;
}

.toolbar-left {
  display: flex;
  align-items: center;
  gap: 10px;
}

.toolbar-title {
  font-size: 18px;
  font-weight: 700;
}

.file-count-badge {
  background: linear-gradient(135deg, rgba(99,102,241,0.15), rgba(139,92,246,0.1));
  color: var(--accent);
  padding: 3px 10px;
  border-radius: 100px;
  font-size: 12px;
  font-weight: 600;
  border: 1px solid rgba(99,102,241,0.2);
}

.sort-badge {
  display: flex;
  align-items: center;
  gap: 5px;
  color: var(--green);
  background: var(--green-bg);
  border: 1px solid var(--green-border);
  padding: 3px 10px;
  border-radius: 100px;
  font-size: 11px;
  font-weight: 600;
}

.toolbar-right { display: flex; gap: 8px; }

/* ── List Table ── */
.list-table-header {
  display: grid;
  grid-template-columns: var(--list-grid-cols, 40px 28px 1fr 70px 80px 1fr);
  gap: 8px;
  padding: 8px 14px;
  font-size: 11px;
  font-weight: 600;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.5px;
  border-bottom: 1px solid var(--border);
}

.list-table-header .sortable {
  cursor: pointer;
  user-select: none;
  transition: color 0.2s;
  display: flex;
  align-items: center;
  gap: 4px;
}

.list-table-header .sortable:hover {
  color: var(--text);
}

.list-table-header .sortable::after {
  content: '';
  font-size: 10px;
  opacity: 0.5;
}

.list-table-header .sortable.sort-asc::after {
  content: '▲';
  opacity: 1;
  color: var(--accent);
}

.list-table-header .sortable.sort-desc::after {
  content: '▼';
  opacity: 1;
  color: var(--accent);
}

.list-table-header span.dragging {
  opacity: 0.5;
  background: var(--surface-active);
  border-radius: var(--radius);
}

.list-table-header span.drag-over-col {
  background: var(--surface-hover);
  border-bottom: 2px solid var(--accent);
}

.col-resizer {
  position: absolute;
  top: 0;
  right: -5px; /* offset to allow easy clicking */
  bottom: 0;
  width: 10px;
  cursor: col-resize;
  z-index: 10;
  opacity: 0;
  transition: opacity 0.2s;
}

.col-resizer:hover, .col-resizer.resizing {
  background: var(--accent);
  opacity: 0.5;
}

.list-table-header > span {
  position: relative; /* for absolute resizer */
}

.file-list {
  flex: 1;
  overflow-y: auto;
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  background: var(--bg-subtle);
}

.file-row {
  display: grid;
  grid-template-columns: var(--list-grid-cols, 40px 28px 1fr 70px 80px 1fr);
  gap: 8px;
  align-items: center;
  padding: 10px 14px;
  font-size: 13px;
  border-bottom: 1px solid var(--border);
  transition: var(--transition);
}

.file-row > span {
  min-width: 0; /* allows text-overflow to work in grid */
}

.file-row:last-child { border-bottom: none; }
.file-row:hover { background: var(--surface-hover); }
.file-row.selected {
  background: var(--surface-active);
  border-left: 3px solid var(--accent);
}

.row-idx {
  font-size: 11px;
  color: var(--text-muted);
  font-weight: 500;
  text-align: center;
}

.row-icon {
  font-size: 16px;
}

.row-name {
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.row-ext {
  font-size: 11px;
  font-weight: 600;
  text-transform: uppercase;
  color: var(--accent);
  background: rgba(99,102,241,0.08);
  padding: 2px 7px;
  border-radius: 4px;
  width: fit-content;
}

.row-size {
  font-size: 12px;
  color: var(--text-secondary);
}

.row-path {
  font-size: 11px;
  color: var(--text-muted);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.list-footer {
  display: flex;
  justify-content: center;
  padding-top: 16px;
}

/* ── Toast ── */
.toast {
  position: fixed;
  bottom: 24px;
  right: 24px;
  background: var(--surface);
  border: 1px solid var(--border-hover);
  padding: 12px 20px;
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 13px;
  font-weight: 500;
  box-shadow: 0 10px 40px -10px rgba(0,0,0,0.5);
  transform: translateY(80px);
  transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  z-index: 200;
}

.toast.show { transform: translateY(0); }
.toast.success { border-color: var(--green-border); }
.toast.success .toast-icon::before { content: '✓'; color: var(--green); }
.toast.error { border-color: rgba(248,113,113,0.3); }
.toast.error .toast-icon::before { content: '✕'; color: var(--red); }
.toast.info .toast-icon::before { content: 'ℹ'; color: var(--accent); }

/* ── Scrollbar ── */
::-webkit-scrollbar { width: 6px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--border-hover); border-radius: 3px; }
::-webkit-scrollbar-thumb:hover { background: rgba(255,255,255,0.15); }

/* ── Rename Panel ── */
.rename-panel {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-height: 0;
  overflow: hidden;
  animation: fadeIn 0.3s ease;
}

.rename-rules {
  display: grid;
  grid-template-columns: 1fr 1fr;
  grid-auto-rows: max-content;
  align-items: start;
  gap: 10px;
  overflow-y: auto;
  flex: 1;
  padding-right: 4px;
}

.rule-card {
  background: var(--bg-subtle);
  border: 1px solid var(--border);
