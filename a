// Rename Logic & Preview
// ═══════════════════════════════════════
function generatePreview() {
  currentPreviewFiles = processedFiles.map((file, index) => {
    let originalName = file.name;
    const isDir = file.isFile === false;
    let ext = isDir ? '' : getExtension(originalName);
    let baseName = isDir ? originalName : originalName.substring(0, originalName.length - (ext ? ext.length + 1 : 0));
    let newExt = ext ? '.' + ext : '';

    // 1. Bul ve Değiştir
    if (document.querySelector('[data-rule="findReplace"]').checked) {
      const find = document.getElementById('r-find').value;
      const replace = document.getElementById('r-replace').value;
      if (find) baseName = baseName.split(find).join(replace);
    }

    // 4. Büyük/Küçük Harf
    if (document.querySelector('[data-rule="caseChange"]').checked) {
      const caseType = document.getElementById('r-case').value;
      if (caseType === 'lower') baseName = baseName.toLowerCase();
      else if (caseType === 'upper') baseName = baseName.toUpperCase();
      else if (caseType === 'title') {
        baseName = baseName.replace(/\w\S*/g, txt => txt.charAt(0).toUpperCase() + txt.substr(1).toLowerCase());
      } else if (caseType === 'sentence') {
        baseName = baseName.charAt(0).toUpperCase() + baseName.slice(1).toLowerCase();
      }
    }

    // 5. Karakter Silme
    if (document.querySelector('[data-rule="removeChars"]').checked) {
      if (document.getElementById('r-rm-spaces').checked) baseName = baseName.replace(/ /g, '');
      if (document.getElementById('r-rm-special').checked) baseName = baseName.replace(/[^a-zA-Z0-9_\-\u00C0-\u017F]/g, '');
      const customRm = document.getElementById('r-rm-custom').value;
      if (customRm) {
        const escaped = customRm.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
        baseName = baseName.replace(new RegExp(`[${escaped}]`, 'g'), '');
      }
    }

    // 6. Regex Replace
    if (document.querySelector('[data-rule="regexReplace"]').checked) {
      const find = document.getElementById('r-regex-find').value;
      const replace = document.getElementById('r-regex-replace').value;
      if (find) {
        try {
          const regex = new RegExp(find, 'g');
          baseName = baseName.replace(regex, replace);
        } catch(e) {}
      }
    }

    // 7. Uzantı Değiştirme
    if (!isDir && document.querySelector('[data-rule="extChange"]').checked) {
      const oldExt = document.getElementById('r-ext-old').value.replace(/^\./, '');
      const replaceExt = document.getElementById('r-ext-new').value.replace(/^\./, '');
      if (oldExt && replaceExt && ext.toLowerCase() === oldExt.toLowerCase()) {
        newExt = '.' + replaceExt;
      }
    }

    // Liste İsimlendirme
    const listRenameRules = document.querySelectorAll('[data-rule="listRename"]:checked');
    if (listRenameRules.length > 0) {
      listRenameRules.forEach(ruleCheckbox => {
        const textarea = ruleCheckbox.closest('.rule-card').querySelector('.list-names-textarea');
        if (textarea) {
          const lines = textarea.value.split('\n').map(l => l.trim()).filter(l => l !== '');
          if (lines[index]) {
            baseName = lines[index];
          }
        }
      });
    }

    // 8. Tarih Ekleme
    if (document.querySelector('[data-rule="dateInsert"]').checked) {
      const format = document.getElementById('r-date-format').value;
      const pos = document.getElementById('r-date-position').value;
      const sep = document.getElementById('r-date-sep').value;
      const now = new Date();
      const yyyy = now.getFullYear();
      const mm = String(now.getMonth() + 1).padStart(2, '0');
      const dd = String(now.getDate()).padStart(2, '0');
      
      let dateStr = '';
      if (format === 'YYYY-MM-DD') dateStr = `${yyyy}-${mm}-${dd}`;
      else if (format === 'DD-MM-YYYY') dateStr = `${dd}-${mm}-${yyyy}`;
      else if (format === 'YYYYMMDD') dateStr = `${yyyy}${mm}${dd}`;
      else if (format === 'DD.MM.YYYY') dateStr = `${dd}.${mm}.${yyyy}`;

      if (pos === 'prefix') baseName = dateStr + sep + baseName;
      else baseName = baseName + sep + dateStr;
    }

    // 2. Önek Sonek
    if (document.querySelector('[data-rule="prefixSuffix"]').checked) {
      const prefix = document.getElementById('r-prefix').value;
      const suffix = document.getElementById('r-suffix').value;
      baseName = prefix + baseName + suffix;
    }

    // 3. Numaralandırma
    if (document.querySelector('[data-rule="numbering"]').checked) {
      const start = parseInt(document.getElementById('r-num-start').value) || 0;
      const step = parseInt(document.getElementById('r-num-step').value) || 1;
      const pos = document.getElementById('r-num-position').value;
      const sep = document.getElementById('r-num-separator').value;
      const pad = parseInt(document.getElementById('r-num-padding').value) || 0;
      
      const num = start + (index * step);
      let numStr = num.toString();
      if (pad > 0) numStr = numStr.padStart(pad, '0');
      
      if (pos === 'prefix') baseName = numStr + sep + baseName;
      else if (pos === 'suffix') baseName = baseName + sep + numStr;
      else if (pos === 'only') baseName = numStr;
    }

    return { file, newName: baseName + newExt };
  });

  renderPreview();
}

function renderPreview() {
  previewList.innerHTML = '';
  currentPreviewFiles.forEach((item, index) => {
    const isSame = item.file.name === item.newName;
    const row = document.createElement('div');
    row.className = 'preview-row';
    row.innerHTML = `
      <span class="preview-idx">${index + 1}</span>
      <span class="preview-old" title="${item.file.name}">${item.file.name}</span>
      <span class="preview-arrow">→</span>
      <span class="preview-new ${isSame ? 'preview-same' : ''}" title="${item.newName}">${item.newName}</span>
    `;
    previewList.appendChild(row);
  });
}

