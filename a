// ═══════════════════════════════════════
// Toast Notification
// ═══════════════════════════════════════
function toast(msg, type = 'info') {
  const t = document.getElementById('toast');
  t.querySelector('.toast-msg').textContent = msg;
  t.className = `toast show ${type}`;
  setTimeout(() => { t.classList.remove('show'); }, 3500);
}

// ═══════════════════════════════════════
// Drop Zone — Mouse Tracking for Glow
// ═══════════════════════════════════════
dropZone.addEventListener('mousemove', (e) => {
  const rect = dropZone.getBoundingClientRect();
  dropZone.style.setProperty('--mouse-x', `${e.clientX - rect.left}px`);
  dropZone.style.setProperty('--mouse-y', `${e.clientY - rect.top}px`);
});

// ═══════════════════════════════════════
// Drag & Drop (External Files)
// ═══════════════════════════════════════
let isReordering = false; // Flag to distinguish internal reordering from external file drop

document.addEventListener('dragover', (e) => {
  if (isReordering) return;
  e.preventDefault();
  if (e.dataTransfer.types.includes('Files')) {
    dropZone.classList.add('drag-over');
    if (!listPanel.classList.contains('hidden')) {
      // Optional: Add a subtle overlay to the list panel when dragging files over it
      listPanel.style.opacity = '0.7';
    }
  }
});

document.addEventListener('dragleave', (e) => {
  if (isReordering) return;
  if (!e.relatedTarget || e.relatedTarget.nodeName === 'HTML') {
    dropZone.classList.remove('drag-over');
    listPanel.style.opacity = '1';
  }
});

document.addEventListener('drop', (e) => {
  if (isReordering) return;
  e.preventDefault();
  dropZone.classList.remove('drag-over');
  listPanel.style.opacity = '1';

  const files = Array.from(e.dataTransfer.files);
  if (files.length > 0) {
    if (window.electronAPI && window.electronAPI.getFilePath) {
      rawEntries = files.map(f => window.electronAPI.getFilePath(f)).filter(Boolean);
    } else {
      rawEntries = files.map(f => f.path).filter(Boolean);
    }

    if (rawEntries.length > 0) {
      showOptionsModal();
    } else {
      toast('Dosya yolları alınamadı.', 'error');
    }
  }
});

dropZone.addEventListener('click', async () => {
  if (window.electronAPI) {
    const dir = await window.electronAPI.selectDirectory();
    if (dir) {
      rawEntries = [dir];
      showOptionsModal();
    }
  } else {
    toast('Bu özellik masaüstü uygulamasında çalışır.', 'error');
  }
});

// ═══════════════════════════════════════
// Options Modal
// ═══════════════════════════════════════
function showOptionsModal() {
  const lastAction = localStorage.getItem('namify-last-action');
  if (lastAction === 'folders') {
    document.getElementById('action-folders').checked = true;
  } else {
    document.getElementById('action-files').checked = true;
  }
  optionsModal.classList.remove('hidden');
}

function hideOptionsModal() {
  optionsModal.classList.add('hidden');
}

closeModal.addEventListener('click', hideOptionsModal);
cancelModal.addEventListener('click', hideOptionsModal);

optionsModal.addEventListener('click', (e) => {
  if (e.target === optionsModal) hideOptionsModal();
});

// ═══════════════════════════════════════
// Process Files — Native Electron Scan
// ═══════════════════════════════════════
processBtn.addEventListener('click', async () => {
  if (!window.electronAPI) {
    toast('Bu özellik sadece masaüstü uygulamasında çalışır.', 'error');
    return;
  }

  const isFilesMode = document.getElementById('action-files').checked;
  const fileMask = document.getElementById('file-mask').value.trim();
  const regexMatch = document.getElementById('regex-match').value.trim();
  const includeSubfolders = document.getElementById('include-subfolders').checked;
  const addSubfolders = document.getElementById('add-subfolders').checked;
  const addRoot = document.getElementById('add-root').checked;

  const options = {
    mode: isFilesMode ? 'files' : 'folders',
    includeSubfolders,
    fileMask,
    regexMatch,
    addSubfolders,
    addRoot,
  };

  localStorage.setItem('namify-last-action', options.mode);

  toast('Dosyalar taranıyor...', 'info');

  try {
    const scannedFiles = await window.electronAPI.scanPaths({ paths: rawEntries, options });

    const newFilesSorted = scannedFiles.sort((a, b) => {
      const dirA = a.path.replace(/[/\\][^/\\]+$/, '');
      const dirB = b.path.replace(/[/\\][^/\\]+$/, '');
      const dirCmp = dirA.localeCompare(dirB, undefined, { numeric: true, sensitivity: 'base' });
      if (dirCmp !== 0) return dirCmp;
      return a.name.localeCompare(b.name, undefined, { numeric: true, sensitivity: 'base' });
    });

    hideOptionsModal();

    if (newFilesSorted.length === 0) {
      toast('Kriterlere uyan dosya bulunamadı.', 'error');
      return;
    }

    // Append to existing list avoiding duplicates
    const existingPaths = new Set(processedFiles.map(f => f.path));
    const uniqueNewFiles = newFilesSorted.filter(f => !existingPaths.has(f.path));

    if (uniqueNewFiles.length === 0) {
      toast('Eklenen dosyalar zaten listede mevcut.', 'info');
      return;
    }

    saveListState(); // Save state for undo before appending
    processedFiles = [...processedFiles, ...uniqueNewFiles];

    renderList();
    toast(`${uniqueNewFiles.length} yeni dosya eklendi.`, 'success');
  } catch (err) {
    toast('Tarama hatası: ' + err.message, 'error');
  }
});

// ═══════════════════════════════════════
// Render File List & Columns
// ═══════════════════════════════════════
let draggedIndices = [];

const columnDefinitions = [
  { id: 'idx', sort: 'index', title: '#', width: '40px', render: (file, index) => `<span class="col-idx row-idx">${index + 1}</span>` },
  { id: 'icon', sort: null, title: '', width: '28px', render: (file, index, isDir, ext) => `<span class="col-icon row-icon">${isDir ? '📁' : getFileIcon(ext)}</span>` },
  { id: 'name', sort: 'name', title: 'Dosya Adı', width: '1fr', render: (file, index, isDir, ext, nameWithoutExt) => `<span class="col-name row-name" title="${file.name}">${nameWithoutExt}</span>` },
  { id: 'ext', sort: 'ext', title: 'Uzantı', width: '70px', render: (file, index, isDir, ext) => `<span class="col-ext row-ext">${ext || (isDir ? 'KLASÖR' : '-')}</span>` },
  { id: 'size', sort: 'size', title: 'Boyut', width: '80px', render: (file) => `<span class="col-size row-size">${formatBytes(file.size)}</span>` },
  { id: 'path', sort: 'path', title: 'Konum', width: '1fr', render: (file, index, isDir, ext, nameWithoutExt, dir) => `<span class="col-path row-path" title="${dir}">${dir}</span>` }
];

let columnOrder = ['idx', 'icon', 'name', 'ext', 'size', 'path'];
let currentSort = { col: null, asc: true };

function renderHeader() {
  const headerContainer = document.getElementById('list-header');
  headerContainer.innerHTML = '';
  const savedWidths = JSON.parse(localStorage.getItem('namify-col-widths') || '{}');
  if (Object.keys(savedWidths).length > 0) {
    columnDefinitions.forEach(c => { if (savedWidths[c.id]) c.width = savedWidths[c.id]; });
  }

  let gridCols = [];
  
  columnOrder.forEach(colId => {
    const colDef = columnDefinitions.find(c => c.id === colId);
    gridCols.push(colDef.width);
  });

  document.documentElement.style.setProperty('--list-grid-cols', gridCols.join(' '));

  columnOrder.forEach(colId => {
    const colDef = columnDefinitions.find(c => c.id === colId);
    gridCols.push(colDef.width);
    
    const span = document.createElement('span');
    span.className = `col-${colId}`;
    if (colDef.sort) {
      span.classList.add('sortable');
      span.setAttribute('data-sort', colDef.sort);
      
      if (currentSort.col === colDef.sort) {
        span.classList.add(currentSort.asc ? 'sort-asc' : 'sort-desc');
      }
    }
    span.setAttribute('draggable', 'true');
    span.textContent = colDef.title;
    // Column Resizer
    const resizer = document.createElement('div');
    resizer.className = 'col-resizer';
    resizer.addEventListener('mousedown', (e) => {
      e.preventDefault();
      e.stopPropagation();
      window.isResizingCol = true;
      let startX = e.pageX;
      let startWidth = span.offsetWidth;

      function onMouseMove(moveEvent) {
        const delta = moveEvent.pageX - startX;
        const newWidth = Math.max(30, startWidth + delta);
        colDef.width = newWidth + 'px';
        
        const newGridCols = columnOrder.map(c => columnDefinitions.find(def => def.id === c).width).join(' ');
        document.documentElement.style.setProperty('--list-grid-cols', newGridCols);
      }

      function onMouseUp() {
        document.removeEventListener('mousemove', onMouseMove);
        document.removeEventListener('mouseup', onMouseUp);
        resizer.classList.remove('resizing');
        document.body.style.cursor = 'default';
        localStorage.setItem('namify-col-widths', JSON.stringify(Object.fromEntries(columnDefinitions.map(c => [c.id, c.width]))));
        window.isResizingCol = false;
        window.wasResizingCol = true;
        setTimeout(() => window.wasResizingCol = false, 200);
      }

      resizer.classList.add('resizing');
      document.body.style.cursor = 'col-resize';
      document.addEventListener('mousemove', onMouseMove);
      document.addEventListener('mouseup', onMouseUp);
    });
    span.appendChild(resizer);

    // Drag events for column reordering
    span.addEventListener('dragstart', (e) => {
      if (window.isResizingCol) {
        e.preventDefault();
        return;
      }
      e.dataTransfer.setData('text/plain', colId);
      span.classList.add('dragging');
      isReordering = true;
    });
    
    span.addEventListener('dragend', () => {
      span.classList.remove('dragging');
      isReordering = false;
      document.querySelectorAll('.list-table-header span').forEach(s => s.classList.remove('drag-over-col'));
    });
    
    span.addEventListener('dragover', (e) => {
      e.preventDefault();
      span.classList.add('drag-over-col');
    });
    
    span.addEventListener('dragleave', () => {
      span.classList.remove('drag-over-col');
    });
    
    span.addEventListener('drop', (e) => {
      e.preventDefault();
      span.classList.remove('drag-over-col');
      const draggedColId = e.dataTransfer.getData('text/plain');
      if (draggedColId && draggedColId !== colId && columnOrder.includes(draggedColId)) {
        const fromIndex = columnOrder.indexOf(draggedColId);
        const toIndex = columnOrder.indexOf(colId);
        
        columnOrder.splice(fromIndex, 1);
        columnOrder.splice(toIndex, 0, draggedColId);
        
        renderHeader();
        renderList();
      }
    });
    
    // Click for sorting
    if (colDef.sort) {
      span.addEventListener('click', (e) => {
        if (window.isResizingCol || window.wasResizingCol) return;
        handleSort(colDef.sort);
      });
    }
    
    headerContainer.appendChild(span);
  });
  
  document.documentElement.style.setProperty('--list-grid-cols', gridCols.join(' '));
}

function renderList() {
  dropZone.classList.add('hidden');
  listPanel.classList.remove('hidden');
  
  // Render header if empty
  if (document.getElementById('list-header').innerHTML === '') {
    renderHeader();
  }
  
  fileList.innerHTML = '';
  fileCountEl.textContent = processedFiles.length;
  statTotal.textContent = processedFiles.length;

  processedFiles.forEach((file, index) => {
    const isDir = file.isFile === false;
    const ext = isDir ? '' : getExtension(file.name);
    const nameWithoutExt = isDir ? file.name : file.name.replace(/\.[^.]+$/, '');
    const dir = file.path ? file.path.replace(/[/\\][^/\\]+$/, '') : '-';

    const row = document.createElement('div');
    row.className = 'file-row';
    row.setAttribute('data-index', index);
    row.setAttribute('draggable', 'true');
    
    // Drag Events for Reordering
    row.addEventListener('dragstart', (e) => {
      isReordering = true;
      if (!row.classList.contains('selected')) {
        document.querySelectorAll('.file-row.selected').forEach(r => r.classList.remove('selected'));
        row.classList.add('selected');
      }
      
      draggedIndices = Array.from(document.querySelectorAll('.file-row.selected'))
                            .map(r => parseInt(r.getAttribute('data-index')))
                            .sort((a, b) => a - b);
                            
      e.dataTransfer.effectAllowed = 'move';
      setTimeout(() => {
        document.querySelectorAll('.file-row.selected').forEach(r => r.style.opacity = '0.5');
      }, 0);
    });
    
    row.addEventListener('dragend', () => {
      isReordering = false;
      document.querySelectorAll('.file-row').forEach(r => r.style.opacity = '1');
    });
    
    row.addEventListener('dragover', (e) => {
      e.preventDefault();
      row.style.background = 'var(--surface-active)';
    });
    
    row.addEventListener('dragleave', () => {
      row.style.background = '';
    });
    
    row.addEventListener('drop', (e) => {
      if (!isReordering) return;
      e.preventDefault();
      row.style.background = '';
      
      if (!draggedIndices || draggedIndices.length === 0) return;
      
      saveListState(); // Kaydet (Ctrl+Z için)
      
      // Determine if we should drop before or after this row based on mouse position
      const rect = row.getBoundingClientRect();
      const isAfter = e.clientY > rect.top + rect.height / 2;
      const targetIndex = isAfter ? index + 1 : index;
      
      const draggedItems = draggedIndices.map(idx => processedFiles[idx]);
      
      // Sondan başa doğru sil (index kaymasını önlemek için)
      for (let i = draggedIndices.length - 1; i >= 0; i--) {
        processedFiles.splice(draggedIndices[i], 1);
      }
      
      // Yeni ekleme noktasını hesapla
      const shift = draggedIndices.filter(idx => idx < targetIndex).length;
      const finalInsertIndex = targetIndex - shift;
      
      processedFiles.splice(finalInsertIndex, 0, ...draggedItems);
      
      renderList();
      
      // Seçimleri geri yükle
      setTimeout(() => {
        const allRows = document.querySelectorAll('.file-row');
        for (let i = 0; i < draggedItems.length; i++) {
          if (allRows[finalInsertIndex + i]) {
            allRows[finalInsertIndex + i].classList.add('selected');
          }
        }
      }, 0);
      
      draggedIndices = [];
    });

    // Selection Events
    row.addEventListener('click', (e) => {
      if (e.ctrlKey || e.metaKey) {
        row.classList.toggle('selected');
      } else if (e.shiftKey) {
        // Simple shift logic: select from last selected to this
        const allRows = Array.from(fileList.children);
        const lastSelected = allRows.findLastIndex(r => r.classList.contains('selected'));
        if (lastSelected !== -1) {
          const start = Math.min(lastSelected, index);
          const end = Math.max(lastSelected, index);
          for (let i = start; i <= end; i++) allRows[i].classList.add('selected');
        } else {
          row.classList.add('selected');
        }
      } else {
        document.querySelectorAll('.file-row.selected').forEach(r => r.classList.remove('selected'));
        row.classList.add('selected');
      }
    });

    row.innerHTML = columnOrder.map(colId => {
      const colDef = columnDefinitions.find(c => c.id === colId);
      return colDef.render(file, index, isDir, ext, nameWithoutExt, dir);
    }).join('');
    fileList.appendChild(row);
  });
}

function handleSort(sortKey) {
  if (!sortKey || processedFiles.length === 0) return;
  
  if (currentSort.col === sortKey) {
    currentSort.asc = !currentSort.asc;
  } else {
    currentSort.col = sortKey;
    currentSort.asc = true;
  }
  
  renderHeader(); // Görsel belirteçleri güncelle
  
  saveListState(); // Geri al (Ctrl+Z) için kaydet
  
  if (sortKey === 'index') {
    processedFiles.reverse();
  } else {
    processedFiles.sort((a, b) => {
      let valA, valB;
      const isDirA = a.isFile === false;
      const isDirB = b.isFile === false;
      
      switch (sortKey) {
        case 'name':
          valA = a.name; valB = b.name;
          break;
        case 'ext':
          valA = isDirA ? '' : getExtension(a.name);
          valB = isDirB ? '' : getExtension(b.name);
          break;
        case 'size':
          valA = a.size || 0; valB = b.size || 0;
          return currentSort.asc ? valA - valB : valB - valA;
        case 'path':
          valA = a.path ? a.path.replace(/[/\\][^/\\]+$/, '') : '';
          valB = b.path ? b.path.replace(/[/\\][^/\\]+$/, '') : '';
          break;
      }
      
      const cmp = String(valA).localeCompare(String(valB), undefined, { numeric: true, sensitivity: 'base' });
      return currentSort.asc ? cmp : -cmp;
    });
  }
  
  renderList();
}

// Global Keyboard Events (Ctrl+A & Delete & Ctrl+Z)
document.addEventListener('keydown', (e) => {
  if (listPanel.classList.contains('hidden') || processedFiles.length === 0) return;
  
  // Prevent catching if inside an input
  if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA') return;

  // Ctrl + A
  if ((e.ctrlKey || e.metaKey) && e.key.toLowerCase() === 'a') {
    e.preventDefault();
    document.querySelectorAll('.file-row').forEach(r => r.classList.add('selected'));
  }

  // Ctrl + Z
  if ((e.ctrlKey || e.metaKey) && e.key.toLowerCase() === 'z') {
    e.preventDefault();
    if (listHistory.length > 0) {
      processedFiles = listHistory.pop();
      renderList();
      toast('Sıralama geri alındı.', 'info');
    }
  }

  // Delete / Backspace
  if (e.key === 'Delete' || e.key === 'Backspace') {
    e.preventDefault();
    const selectedRows = document.querySelectorAll('.file-row.selected');
    if (selectedRows.length > 0) {
      saveListState(); // Kaydet (Ctrl+Z için)
      
      // Get indices to delete in reverse order to avoid index shifting
      const indices = Array.from(selectedRows).map(r => parseInt(r.getAttribute('data-index'))).sort((a,b) => b-a);
      indices.forEach(idx => processedFiles.splice(idx, 1));
      renderList();
      toast(`${selectedRows.length} dosya listeden çıkarıldı.`, 'info');
      
      if (processedFiles.length === 0) {
        listPanel.classList.add('hidden');
        dropZone.classList.remove('hidden');
      }
    }
  }
});

