applyRenameBtn.addEventListener('click', async () => {
  if (!window.electronAPI) {
    toast('Bu özellik masaüstü uygulamasında çalışır.', 'error');
    return;
  }

  const actionType = document.getElementById('action-type').value;

  const itemsToProcess = currentPreviewFiles
    .filter(item => {
      if (actionType === 'rename') return item.file.name !== item.newName;
      return true; // For move and copy, process all regardless of name change
    })
    .map(item => ({
      path: item.file.path, // Pass full path for exact targeting
      oldName: item.file.name,
      newName: item.newName
    }));

  if (itemsToProcess.length === 0) {
    toast('İşlem yapılacak dosya bulunamadı veya isimleri aynı.', 'info');
    return;
  }

  let targetFolder = null;
  if (actionType === 'move' || actionType === 'copy') {
    const selected = await window.electronAPI.selectDirectory();
    if (!selected) return; // Kullanıcı iptal etti
    targetFolder = selected;
  }

  const folder = processedFiles[0]?.path ? processedFiles[0].path.replace(/[/\\][^/\\]+$/, '') : null;
  if (!folder && actionType === 'rename') {
    toast('Klasör yolu bulunamadı.', 'error');
    return;
  }

  let actionName = actionType === 'rename' ? 'İsimlendirme' : (actionType === 'move' ? 'Taşıma' : 'Kopyalama');
  toast(`${actionName} başlatıldı (${itemsToProcess.length} dosya)...`, 'info');

  const result = await window.electronAPI.renameFiles({ folder, files: itemsToProcess, actionType, targetFolder });

  if (result.errors === 0) {
    toast(`${result.success} dosya başarıyla adlandırıldı!`, 'success');
    let currentTotalRenamed = parseInt(statRenamed.textContent) || 0;
    statRenamed.textContent = currentTotalRenamed + result.success;
    
    // Reset lists
    renamePanel.classList.add('hidden');
    dropZone.classList.remove('hidden');
    processedFiles = [];
    rawEntries = [];
    statTotal.textContent = '0';
    switchView('home');
  } else {
    toast(`${result.errors} dosyada hata oluştu. Lütfen çakışmaları kontrol edin.`, 'error');
  }
});

// ═══════════════════════════════════════
// History & Undo Logic
// ═══════════════════════════════════════
async function loadHistoryUI() {
  if (!window.electronAPI) {
    historyList.innerHTML = '<div style="padding:20px; text-align:center;">Masaüstü uygulaması gereklidir.</div>';
    return;
  }

  historyList.innerHTML = '<div style="padding:20px; text-align:center; color:var(--text-muted)">Yükleniyor...</div>';
  
  const history = await window.electronAPI.getHistory();
  
  if (!history || history.length === 0) {
    historyList.innerHTML = '<div style="padding:20px; text-align:center; color:var(--text-muted)">Henüz hiçbir işlem yapılmamış.</div>';
    return;
  }

  historyList.innerHTML = '';
  
  history.forEach((batch) => {
    const date = new Date(batch.timestamp);
    const dateStr = date.toLocaleDateString() + ' ' + date.toLocaleTimeString();
    
    const row = document.createElement('div');
    row.className = 'file-row';
    row.style.gridTemplateColumns = '140px 1fr 80px 100px';
    row.innerHTML = `
      <span class="row-idx" style="text-align:left;">${dateStr}</span>
      <span class="row-name" title="${batch.folder}">
        ${batch.count} dosya yeniden adlandırıldı
        <div style="font-size:10px; color:var(--text-muted); margin-top:2px; overflow:hidden; text-overflow:ellipsis;">${batch.folder || ''}</div>
      </span>
      <span class="row-size">${batch.count}</span>
      <span class="row-path">
        <button class="btn btn-sm btn-ghost-danger undo-btn" data-id="${batch.id}">Geri Al</button>
      </span>
    `;
    historyList.appendChild(row);
  });

  document.querySelectorAll('.undo-btn').forEach(btn => {
    btn.addEventListener('click', async (e) => {
      const id = e.target.getAttribute('data-id');
      if (confirm('Bu işlemi geri almak (eski isimlere dönmek) istediğinize emin misiniz?')) {
        toast('Geri alma işlemi başlatıldı...', 'info');
        const res = await window.electronAPI.undoBatch(id);
        if (res.success) {
          toast(`${res.undone} dosya eski ismine döndürüldü!`, 'success');
          loadHistoryUI(); // reload list
        } else {
          toast('Hata: ' + (res.error || 'Bilinmeyen bir hata oluştu.'), 'error');
        }
      }
    });
  });
}

