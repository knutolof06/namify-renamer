function showCustomPrompt(msg, defaultValue, callback) {
  const modal = document.getElementById('custom-prompt');
  document.getElementById('custom-prompt-msg').textContent = msg;
  const input = document.getElementById('custom-prompt-input');
  input.value = defaultValue;
  modal.classList.remove('hidden');
  input.focus();

  const handleClose = () => {
    modal.classList.add('hidden');
    cleanUp();
  };

  const handleOk = () => {
    callback(input.value.trim());
    handleClose();
  };

  const btnCloseArr = modal.querySelectorAll('.btn-close-prompt');
  const btnOk = document.getElementById('custom-prompt-ok');

  const onKey = (e) => {
    if (e.key === 'Enter') handleOk();
    if (e.key === 'Escape') handleClose();
  };

  btnCloseArr.forEach(b => b.addEventListener('click', handleClose));
  btnOk.addEventListener('click', handleOk);
  input.addEventListener('keydown', onKey);

  function cleanUp() {
    btnCloseArr.forEach(b => b.removeEventListener('click', handleClose));
    btnOk.removeEventListener('click', handleOk);
    input.removeEventListener('keydown', onKey);
  }
}

