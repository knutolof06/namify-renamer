<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Namify — Dosya İsmi Düzenleyici</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/style.css" />
</head>
<body>
  <!-- Custom Title Bar -->
  <div id="titlebar">
    <div class="titlebar-drag">
      <svg class="titlebar-logo" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="url(#grad1)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <defs><linearGradient id="grad1" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" style="stop-color:#818cf8"/><stop offset="100%" style="stop-color:#c084fc"/></linearGradient></defs>
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/>
      </svg>
      <span class="titlebar-title">Namify</span>
    </div>
    <div class="titlebar-controls">
      <button class="tb-btn tb-minimize" id="tb-min">─</button>
      <button class="tb-btn tb-maximize" id="tb-max">□</button>
      <button class="tb-btn tb-close" id="tb-close">✕</button>
    </div>
  </div>

  <div id="app">
    <!-- Ambient Background -->
    <div class="ambient-bg">
      <div class="orb orb-1"></div>
      <div class="orb orb-2"></div>
      <div class="orb orb-3"></div>
    </div>

    <!-- Sidebar -->
    <aside id="sidebar">
      <div class="sidebar-top">
        <div class="logo-section">
          <div class="logo-mark" style="background: transparent; box-shadow: none;">
            <img src="/icon.png" width="32" height="32" style="border-radius: 8px;">
          </div>
          <div>
            <h1 class="logo-text">Namify</h1>
            <p class="logo-sub">Dosya İsmi Düzenleyici</p>
          </div>
        </div>

        <nav class="sidebar-nav">
          <button class="nav-item active" data-view="home">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            Ana Sayfa
          </button>
          <button class="nav-item" data-view="history" id="nav-history">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            Geçmiş
          </button>
          <button class="nav-item" data-view="settings">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
            Ayarlar
          </button>
        </nav>
      </div>

      <div class="sidebar-stats">
        <div class="stat-card">
          <span class="stat-num" id="stat-total">0</span>
          <span class="stat-label">Toplam Dosya</span>
        </div>
        <div class="stat-card">
          <span class="stat-num" id="stat-renamed">0</span>
          <span class="stat-label">Düzenlenen</span>
        </div>
      </div>
    </aside>

    <!-- Main Content -->
    <main id="main-content">
      <!-- Drop Zone -->
      <div id="drop-zone" class="drop-zone">
        <div class="drop-inner">
          <div class="drop-icon-wrapper">
            <div class="drop-icon-ring"></div>
            <div class="drop-icon-ring ring-2"></div>
            <svg class="drop-icon" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
              <polyline points="17 8 12 3 7 8"/>
              <line x1="12" x2="12" y1="3" y2="15"/>
            </svg>
          </div>
          <h2 class="drop-title">Dosyaları Sürükleyip Bırakın</h2>
          <p class="drop-subtitle">veya bir klasör seçmek için tıklayın</p>
          <div class="drop-badge">
            <span class="badge-dot"></span>
            Tüm dosya türleri desteklenir
          </div>
        </div>
      </div>

      <!-- Options Modal -->
      <div id="options-modal" class="modal-overlay hidden">
        <div class="modal">
          <div class="modal-header">
            <h3>Dosya Ekleme Seçenekleri</h3>
            <button id="close-modal" class="modal-close-btn">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
          </div>

          <div class="modal-body">
            <!-- Option 1 -->
            <div class="option-block">
              <input type="radio" name="add-action" id="action-files" value="files" checked>
              <div class="option-content">
                <div class="option-header" onclick="document.getElementById('action-files').checked = true">
                  <div class="option-icon files-icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/><polyline points="13 2 13 9 20 9"/></svg>
                  </div>
                  <div>
                    <span class="option-label">Dosyaları Klasörlere Ekle</span>
                    <span class="option-desc">Dosyaları filtreleyerek listeye ekleyin</span>
                  </div>
                </div>
                <div class="option-details">
                  <label class="toggle-row">
                    <span>Alt klasörleri dahil et</span>
                    <div class="toggle-switch">
                      <input type="checkbox" id="include-subfolders">
                      <span class="toggle-slider"></span>
                    </div>
                  </label>
                  <div class="field-group">
                    <label class="field-label">Dosya adı maskesi</label>
                    <input type="text" id="file-mask" class="field-input" placeholder="Örn: *.jpg, *.png">
                  </div>
                  <div class="field-group">
                    <label class="field-label">Düzenli ifade eşleşmesi (Regex)</label>
                    <input type="text" id="regex-match" class="field-input" placeholder="Örn: ^IMG_[0-9]+">
                  </div>
                </div>
              </div>
            </div>

            <!-- Option 2 -->
            <div class="option-block">
              <input type="radio" name="add-action" id="action-folders" value="folders">
              <div class="option-content">
                <div class="option-header" onclick="document.getElementById('action-folders').checked = true">
                  <div class="option-icon folders-icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
                  </div>
                  <div>
                    <span class="option-label">Klasör Ekle</span>
                    <span class="option-desc">Klasör yapısını listeye aktarın</span>
                  </div>
                </div>
                <div class="option-details">
                  <label class="toggle-row">
                    <span>Alt klasör ekle</span>
                    <div class="toggle-switch">
                      <input type="checkbox" id="add-subfolders">
                      <span class="toggle-slider"></span>
                    </div>
                  </label>
                  <label class="toggle-row">
                    <span>Kök klasör ekle</span>
                    <div class="toggle-switch">
                      <input type="checkbox" id="add-root">
                      <span class="toggle-slider"></span>
                    </div>
                  </label>
                </div>
              </div>
            </div>
          </div>

          <div class="modal-footer">
            <button id="cancel-modal" class="btn btn-ghost">İptal</button>
            <button id="process-btn" class="btn btn-primary">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
              Listeye Ekle
            </button>
          </div>
        </div>
      </div>

      <!-- File List Panel -->
      <div id="list-panel" class="list-panel hidden">
        <div class="list-toolbar">
          <div class="toolbar-left">
            <h3 class="toolbar-title">Dosya Listesi</h3>
            <div class="file-count-badge"><span id="file-count">0</span> dosya</div>
            <div class="sort-badge">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
              Windows Sıralaması
            </div>
          </div>
          <div class="toolbar-right">
            <!-- 'Daha Ekle' button removed -->
            <button id="clear-list" class="btn btn-sm btn-ghost-danger">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
              Temizle
            </button>
          </div>
        </div>

        <div id="list-header" class="list-table-header"></div>

        <div id="file-list" class="file-list"></div>

        <div class="list-footer">
          <button id="rename-btn" class="btn btn-primary btn-lg">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
            İsimleri Düzenle
          </button>
        </div>
      </div>

      <!-- ═══ RENAME PANEL ═══ -->
      <div id="rename-panel" class="rename-panel hidden">
        <div class="list-toolbar">
          <div class="toolbar-left">
            <h3 class="toolbar-title">İsim Düzenleme</h3>
            <div class="file-count-badge"><span id="rename-file-count">0</span> dosya</div>
          </div>
          <div class="toolbar-right" style="gap: 8px;">
            <button id="btn-toggle-layout" class="btn btn-sm btn-outline" title="Görünümü Değiştir" style="padding: 4px; display: flex; align-items: center; justify-content: center;">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="12" y1="3" x2="12" y2="21"/></svg>
            </button>
            <button id="btn-add-custom-list-rule" class="btn btn-sm btn-primary" style="padding: 4px 8px; font-size: 11px;">+ Yeni Liste Kuralı Ekle</button>
            <button id="btn-import-list" class="btn btn-sm btn-outline" style="padding: 4px 8px; font-size: 11px;">İçe Aktar</button>
            <button id="btn-export-list" class="btn btn-sm btn-outline" style="padding: 4px 8px; font-size: 11px;">Dışa Aktar</button>
            <button id="back-to-list" class="btn btn-sm btn-outline">← Listeye Dön</button>
          </div>
        </div>

        <!-- Rename Layout Container -->
        <div id="rename-layout-container" class="layout-stack">

          <!-- LEFT: Rules Area -->
          <div id="rename-rules-area" class="panel-area">
            <div class="rename-rules">
              <!-- 1. Bul ve Değiştir -->
              <div class="rule-card">
                <label class="rule-header">
                  <input type="checkbox" class="rule-toggle" data-rule="findReplace">
                  <span class="rule-title">1. Bul ve Değiştir</span>
                </label>
                <div class="rule-body">
                  <div class="field-row">
                    <div class="field-group"><label class="field-label">Bul</label><input type="text" id="r-find" class="field-input" placeholder="IMG_"></div>
                    <div class="field-group"><label class="field-label">Değiştir</label><input type="text" id="r-replace" class="field-input" placeholder="Foto_"></div>
                  </div>
                </div>
              </div>

              <!-- 2. Önek / Sonek -->
              <div class="rule-card">
                <label class="rule-header">
                  <input type="checkbox" class="rule-toggle" data-rule="prefixSuffix">
                  <span class="rule-title">2. Önek / Sonek Ekle</span>
                </label>
                <div class="rule-body">
                  <div class="field-row">
                    <div class="field-group"><label class="field-label">Önek</label><input type="text" id="r-prefix" class="field-input" placeholder="proje_"></div>
                    <div class="field-group"><label class="field-label">Sonek</label><input type="text" id="r-suffix" class="field-input" placeholder="_final"></div>
                  </div>
                </div>
              </div>

              <!-- 3. Numaralandırma -->
              <div class="rule-card">
                <label class="rule-header">
                  <input type="checkbox" class="rule-toggle" data-rule="numbering">
                  <span class="rule-title">3. Numaralandırma</span>
                </label>
                <div class="rule-body">
                  <div class="field-row">
                    <div class="field-group"><label class="field-label">Başlangıç</label><input type="number" id="r-num-start" class="field-input" value="1" min="0"></div>
                    <div class="field-group"><label class="field-label">Artış</label><input type="number" id="r-num-step" class="field-input" value="1" min="1"></div>
                    <div class="field-group"><label class="field-label">Konum</label>
                      <select id="r-num-position" class="field-input">
                        <option value="prefix">Başına</option>
                        <option value="suffix">Sonuna</option>
                        <option value="only">Sadece Numara</option>
                      </select>
                    </div>
                  </div>
                  <div class="field-row" style="margin-top:8px;">
                    <div class="field-group"><label class="field-label">Ayraç</label><input type="text" id="r-num-separator" class="field-input" value="_" placeholder="_ - . boşluk"></div>
                    <div class="field-group">
                      <label class="field-label">Sıfır Doldurma</label>
                      <select id="r-num-padding" class="field-input">
                        <option value="0">Yok — 1, 2, 10, 100</option>
                        <option value="2">2 basamak — 01, 02, 10</option>
                        <option value="3">3 basamak — 001, 002, 010</option>
                        <option value="4">4 basamak — 0001, 0002</option>
                      </select>
                    </div>
                  </div>
                </div>
              </div>

              <!-- 4. Büyük / Küçük Harf -->
              <div class="rule-card">
                <label class="rule-header">
                  <input type="checkbox" class="rule-toggle" data-rule="caseChange">
                  <span class="rule-title">4. Büyük / Küçük Harf</span>
                </label>
                <div class="rule-body">
                  <select id="r-case" class="field-input">
                    <option value="lower">tümü küçük harf</option>
                    <option value="upper">TÜMÜ BÜYÜK HARF</option>
                    <option value="title">İlk Harfler Büyük</option>
                    <option value="sentence">İlk harf büyük</option>
                  </select>
                </div>
              </div>

              <!-- 5. Karakter Silme -->
              <div class="rule-card">
                <label class="rule-header">
                  <input type="checkbox" class="rule-toggle" data-rule="removeChars">
                  <span class="rule-title">5. Karakter Silme</span>
                </label>
                <div class="rule-body">
                  <div class="field-row">
                    <label class="toggle-row"><span>Boşlukları kaldır</span><div class="toggle-switch"><input type="checkbox" id="r-rm-spaces"><span class="toggle-slider"></span></div></label>
                    <label class="toggle-row"><span>Özel karakterleri kaldır</span><div class="toggle-switch"><input type="checkbox" id="r-rm-special"><span class="toggle-slider"></span></div></label>
                  </div>
                  <div class="field-group" style="margin-top:8px;">
                    <label class="field-label">Belirli karakterleri sil</label>
                    <input type="text" id="r-rm-custom" class="field-input" placeholder="Örn: ()[]#">
                  </div>
                </div>
              </div>

              <!-- 6. Regex ile Değiştirme -->
              <div class="rule-card">
                <label class="rule-header">
                  <input type="checkbox" class="rule-toggle" data-rule="regexReplace">
                  <span class="rule-title">6. Regex ile Değiştirme</span>
                </label>
                <div class="rule-body">
                  <div class="field-row">
                    <div class="field-group"><label class="field-label">Regex Deseni</label><input type="text" id="r-regex-find" class="field-input" placeholder="Örn: ^IMG_(\d+)"></div>
                    <div class="field-group"><label class="field-label">Yerine Koy</label><input type="text" id="r-regex-replace" class="field-input" placeholder="Örn: Foto_$1"></div>
                  </div>
                </div>
              </div>

              <!-- 7. Uzantı Değiştirme -->
              <div class="rule-card">
                <label class="rule-header">
                  <input type="checkbox" class="rule-toggle" data-rule="extChange">
                  <span class="rule-title">7. Uzantı Değiştirme</span>
                </label>
                <div class="rule-body">
                  <div class="field-row">
                    <div class="field-group"><label class="field-label">Eski uzantı</label><input type="text" id="r-ext-old" class="field-input" placeholder=".jpeg"></div>
                    <div class="field-group"><label class="field-label">Yeni uzantı</label><input type="text" id="r-ext-new" class="field-input" placeholder=".jpg"></div>
                  </div>
                </div>
              </div>

              <!-- 8. Tarih Ekleme -->
              <div class="rule-card">
                <label class="rule-header">
                  <input type="checkbox" class="rule-toggle" data-rule="dateInsert">
                  <span class="rule-title">8. Tarih Ekleme</span>
                </label>
                <div class="rule-body">
                  <div class="field-row">
                    <div class="field-group"><label class="field-label">Tarih formatı</label>
                      <select id="r-date-format" class="field-input">
                        <option value="YYYY-MM-DD">2026-04-22</option>
                        <option value="DD-MM-YYYY">22-04-2026</option>
                        <option value="YYYYMMDD">20260422</option>
                        <option value="DD.MM.YYYY">22.04.2026</option>
                      </select>
                    </div>
                    <div class="field-group"><label class="field-label">Konum</label>
                      <select id="r-date-position" class="field-input">
                        <option value="prefix">Başına</option>
                        <option value="suffix">Sonuna</option>
                      </select>
                    </div>
                    <div class="field-group"><label class="field-label">Ayraç</label><input type="text" id="r-date-sep" class="field-input" value="_"></div>
                  </div>
                </div>
              </div>
            </div><!-- /.rename-rules -->
          </div><!-- /#rename-rules-area -->

          <!-- RESIZER -->
          <div id="layout-resizer" class="layout-resizer"></div>

          <!-- RIGHT: Preview Area -->
          <div id="preview-section-area" class="panel-area">
            <div class="preview-section">
              <div class="preview-header">
                <h4>Önizleme</h4>
                <span class="preview-hint">Eski Ad → Yeni Ad</span>
              </div>
              <div id="preview-list" class="preview-list"></div>
            </div>
          </div><!-- /#preview-section-area -->

        </div><!-- /#rename-layout-container -->

        <div class="rename-footer" style="display: flex; gap: 15px; justify-content: flex-end; align-items: center;">
          <select id="action-type" class="field-input" style="width: auto; min-width: 250px; font-size: 14px;">
            <option value="rename">Bulunduğu Yerde Adlandır</option>
            <option value="move">Yeni Klasöre Taşı</option>
            <option value="copy">Yeni Klasöre Kopyala</option>
          </select>
          <button id="apply-rename" class="btn btn-primary btn-lg">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            <span id="apply-rename-text">Yeniden Adlandır</span>
          </button>
        </div>
      </div>

      <!-- ═══ HISTORY PANEL ═══ -->
      <div id="history-panel" class="history-panel hidden">
        <div class="list-toolbar">
          <div class="toolbar-left">
            <h3 class="toolbar-title">İşlem Geçmişi</h3>
            <div class="file-count-badge">Son 50 İşlem</div>
          </div>
        </div>

        <div class="list-table-header" style="grid-template-columns: 140px 1fr 80px 100px;">
          <span class="col-idx">Tarih</span>
          <span class="col-name">İşlem Özeti</span>
          <span class="col-size">Dosya</span>
          <span class="col-path">Geri Al</span>
        </div>

        <div id="history-list" class="file-list">
          <div style="padding:20px; text-align:center; color:var(--text-muted)">Geçmiş yükleniyor...</div>
        </div>
      </div>

      <!-- ═══ SETTINGS PANEL ═══ -->
      <div id="settings-panel" class="settings-panel hidden">
        <div class="list-toolbar">
          <div class="toolbar-left">
            <h3 class="toolbar-title">Ayarlar</h3>
          </div>
        </div>

        <div class="rule-card" style="margin-top: 20px;">
          <div class="rule-header" style="cursor: default;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="color:var(--accent);"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
            <span class="rule-title" style="margin-left: 8px; font-size: 15px;">Uygulama Teması</span>
          </div>
          <div class="rule-body" style="display: block;">
            <div class="theme-grid">
              <label class="theme-option">
                <input type="radio" name="appTheme" value="midnight" checked>
