let rawEntries = [];
let processedFiles = [];
let currentPreviewFiles = [];
let listHistory = []; // For Ctrl+Z

function saveListState() {
  listHistory.push([...processedFiles]);
  if (listHistory.length > 50) listHistory.shift();
}

// ═══════════════════════════════════════
// Theme Initialization
// ═══════════════════════════════════════
