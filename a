const { app, BrowserWindow, ipcMain, dialog, shell } = require('electron');
const path = require('path');
const fs = require('fs');

let mainWindow;

// ── History Management ──
function getHistoryPath() {
  return path.join(app.getPath('userData'), 'namify-history.json');
}

function loadHistory() {
  try {
    const data = fs.readFileSync(getHistoryPath(), 'utf-8');
    return JSON.parse(data);
  } catch (e) {
    return [];
  }
}

function saveHistory(history) {
  try {
    // Keep only last 50 batches
    if (history.length > 50) history = history.slice(0, 50);
    fs.writeFileSync(getHistoryPath(), JSON.stringify(history, null, 2), 'utf-8');
  } catch (e) {
    console.error("Geçmiş kaydedilemedi", e);
  }
}

function createWindow() {
  mainWindow = new BrowserWindow({
    width: 1100,
    height: 750,
    minWidth: 800,
    minHeight: 550,
    frame: false,
    webPreferences: {
      preload: path.join(__dirname, 'preload.cjs'),
      nodeIntegration: false,
      contextIsolation: true,
    },
    backgroundColor: '#0a0a0f',
    show: false,
  });

  mainWindow.once('ready-to-show', () => mainWindow.show());

  // In development, load from Vite
  if (process.env.NODE_ENV === 'development') {
    mainWindow.loadURL('http://localhost:5173');
  } else {
    mainWindow.loadFile(path.join(__dirname, 'dist/index.html'));
  }
}

const { autoUpdater } = require('electron-updater');

app.whenReady().then(() => {
  createWindow();

  // Auto-Update logic
  if (process.env.NODE_ENV !== 'development') {
    autoUpdater.checkForUpdatesAndNotify();

    autoUpdater.on('update-available', () => {
      mainWindow.webContents.send('update-message', 'Yeni güncelleme bulundu, sessizce indiriliyor lütfen bekleyin...', 'info');
    });

    autoUpdater.on('update-not-available', () => {
      mainWindow.webContents.send('update-message', 'Zaten en güncel sürümü kullanıyorsunuz.', 'success');
    });

    autoUpdater.on('error', (err) => {
      mainWindow.webContents.send('update-message', 'Güncelleme kontrolünde hata: ' + err.message, 'error');
    });

    autoUpdater.on('update-downloaded', () => {
      dialog.showMessageBox(mainWindow, {
        type: 'info',
        title: 'Güncelleme Hazır',
        message: 'Uygulamanın yeni bir sürümü indirildi. Şimdi yüklenip yeniden başlatılsın mı?',
        buttons: ['Evet', 'Daha Sonra']
      }).then((result) => {
        if (result.response === 0) {
          autoUpdater.quitAndInstall();
        }
      });
    });
  }
});

app.on('window-all-closed', () => {
  if (process.platform !== 'darwin') app.quit();
});

// ── Window Controls ──
process.on('uncaughtException', (error) => {
  console.error('Uncaught Exception:', error);
});
process.on('unhandledRejection', (reason, promise) => {
